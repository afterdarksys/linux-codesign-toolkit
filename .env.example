# Linux Code Signing Toolkit API Configuration

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=false

# Security
SECRET_KEY=your-super-secret-key-change-this-in-production-please-make-it-long-and-random
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Database
DATABASE_URL=sqlite+aiosqlite:///./codesign_api.db

# File Storage
UPLOAD_DIRECTORY=./uploads
MAX_FILE_SIZE=524288000  # 500MB
CERTIFICATE_DIRECTORY=./certificates
KEYSTORE_DIRECTORY=./keystores

# Signing Tools Paths
OSSLSIGNCODE_PATH=osslsigncode
JARSIGNER_PATH=jarsigner
KEYTOOL_PATH=keytool
CODESIGN_PATH=codesign
ISIGN_PATH=isign

# Default URLs
DEFAULT_TIMESTAMP_URL=http://timestamp.digicert.com
BASE_DOWNLOAD_URL=http://localhost:8000/api/v1/download

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000

# Logging
LOG_LEVEL=INFO
LOG_FILE=./codesign_api.log

# JIRA Integration (optional)
# JIRA_URL=https://yourcompany.atlassian.net
# JIRA_USERNAME=your-username
# JIRA_TOKEN=your-api-token
# JIRA_PROJECT=PROJ